            bindings = <&kp L>
                , <&kp Y>;
        };

        // mp
        m_p: m_p {
            label = "&M_P";
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            tap-ms = <5>;
            wait-ms = <5>;
            bindings = <&kp M>
                , <&kp P>;
        };

        // ry
        r_y: r_y {
            label = "&R_Y";
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            tap-ms = <5>;
            wait-ms = <5>;
            bindings = <&kp R>
                , <&kp Y>;
        };

        // rm
        r_m: r_m {
            label = "&R_M";
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            tap-ms = <5>;
            wait-ms = <5>;
            bindings = <&kp R>
                , <&kp M>;
        };

        // sp
        s_p: s_p {
            label = "&S_P";
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            tap-ms = <5>;
            wait-ms = <5>;
            bindings = <&kp S>
                , <&kp P>;
        };

        // ok
        o_k: o_k {
            label = "&O_K";
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            tap-ms = <5>;
