                , <&kp K>;
        };

        // ow
        o_w: o_w {
            label = "&O_W";
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            tap-ms = <5>;
            wait-ms = <5>;
            bindings = <&kp O>
                , <&kp W>;
        };

        // ct
        c_t: c_t {
            label = "&C_T";
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            tap-ms = <5>;
