    keymap {
        compatible = "zmk,keymap";

        ALPHA {
/*
 *  ╭─────────────────────╮      ╭─────────────────────╮
 *  │   w   m   d   l   _ │      │  _   i   o   u   b  │
 *  │   s   c   t   r     │      │      e   a   h  A2  │
 *  ╰────────╮  _   n   ' │      │ shf spc  _ ╭────────╯
 *           ╰────────────╯      ╰────────────╯
 */
            display-name = "Alphabet";

            bindings = <
 &kp W &ht_mp 0 M &kp D &ht_ly 0 L &none /* */ &none &ht_ing 0 I &ht_you 0 O &ht_qu 0 U &ht_by 0 B
 &ht LCTRL S &ht_ck 0 C &ht_ty 0 T &ht_ry 0 R /* */ &ht_ye 0 E &ht_ay 0 A &kp H &sl ALPHA2
 &none &lt SYM N &ht_npi GRAVE SQT /* */ &sk RIGHT_SHIFT &lt NAV SPACE &none
            >;

            label = "Alphabet";
        };

        ALPHA2 {
/*
 *  ╭─────────────────────╮      ╭─────────────────────╮
 *  │   _   z   k   j   _ │      │  _   y   x   q   _  │
 *  │ .hs   p   f   g     │      │      ,   .   v   _  │
 *  ╰────────╮  _  gui  _ │      │ shf alt  _ ╭────────╯
 *           ╰────────────╯      ╰────────────╯
 */
            display-name = "Alphabet2";

            bindings = <
 &none &kp Z &ht_ok 0 K &ht_jj 0 J &none /* */ &none &ht_you 0 Y &ht_xp 0 X &kp Q &none
 &sk LC(LA(LG(LSHFT))) &ht_sp 0 P &ht_fl 0 F &ht_gr 0 G /* */ &ht_npi LS(N1) COMMA &ht_npi LS(FSLH) DOT &kp V &trans
 &none &kp LGUI &none /* */ &kp RSHFT &kp RALT &none
            >;

            label = "Alphabet2";
        };

        SYMNUM {
/*
 *  ╭─────────────────────╮      ╭─────────────────────╮
 *  │   _  tab 49  b/d  _ │      │  _   =   ;   -   _  │
 *  │   5  38  27  16     │      │      (   )   /   0  │
 *  ╰────────╮  _   _   _ │      │ shf alt  _ ╭────────╯
 *           ╰────────────╯      ╰────────────╯
 */
            display-name = "SymNum";

            bindings = <
 &trans &kp TAB &ht_npi N9 N4 &ht DEL LA(BSPC) &trans /* */ &trans &mt LS(EQUAL) EQUAL &ht_npi LS(SEMI) SEMI &ht LS(MINUS) MINUS &trans
 &mt LS(N5) N5 &ht_npi N8 N3 &ht_npi N7 N2 &ht_npi N6 N1 /* */ &ht_npi LBKT LS(N9) &ht_npi RBKT LS(N0) &ht_npi BSLH FSLH &kp N0
 &none &trans &trans /* */ &kp RSHFT &kp RALT &none
            >;

            label = "SymNum";
        };

        VIMNAV {
/*
 *  ╭─────────────────────╮      ╭─────────────────────╮
 *  │ :fq  .[  ._  .]   _ │      │  _   %  pdn pup  _  │
 *  │ :fw  alt shf gui    │      │      h   j   k   l  │
 *  ╰────────╮  _  WIN  _ │      │  _   _   _ ╭────────╯
 *           ╰────────────╯      ╰────────────╯
 */
            display-name = "VimNav";

            bindings = <
 &spacefq &kp LS(LG(LBKT)) &kp LG(LS(SPACE)) &kp LS(RG(RBKT)) &trans /* */ &trans &kp LS(N5) &kp LC(D) &kp LC(U) &trans
 &spacefw &sk LALT &sk LSHFT &sk LGUI /* */ &ht_npi H LEFT &ht_npi J DOWN &ht_npi K UP &ht_npi L RIGHT
 &none &mo WIN &trans /* */ &trans &trans &none
            >; 

            label = "VimNav";
        };

        Window {
/*
 *  ╭─────────────────────╮      ╭─────────────────────╮
 *  │   _  .-  .h  .j   _ │      │  _  .k  .l  .+   _  │
 *  │   _   _  :h  :j     │      │     :k  :l   _   _  │
 *  ╰────────╮  _   _   _ │      │  _   _   _ ╭────────╯
 *           ╰────────────╯      ╰────────────╯
 */
            bindings = <
 &none &kp MINUS &kp LA(LS(H)) &kp LA(LS(J)) &none /* */ &none &kp LA(LS(K)) &kp LA(LS(L)) &kp LA(LS(EQUAL)) &none
 &none &none &nvim_win_l &nvim_win_dn /* */ &nvim_win_up &nvim_win_r &none &none
 &none &none &none /* */ &none &none &none
            >;

            label = "WIN";
        };
    };

    conditional_layers { compatible = "zmk,conditional-layers"; };
};

/* # Index : GPIO (RP2040) */
/* 0  : GP0 */
/* 1  : GP1 */
/* 2  : GP2 */
/* 3  : GP3 */
/* 4  : GP4 */
/* 5  : GP21 */
/* 6  : GP22 */
/* 7  : GP26 */
/* 8  : GP27 */
/* 9  : GP28 */
/* 10 : GP8 */
/* 11 : GP7 */
/* 12 : GP6 */
