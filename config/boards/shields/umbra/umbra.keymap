    combos {
        compatible = "zmk,combos";

        caps_word {
            bindings = <&caps_word>;
            key-positions = <21 22>;
            require-prior-idle-ms = <500>;
        };

        ret {
            bindings = <&kp RET>;
            key-positions = <14 16>;
            timeout-ms = <200>;
            require-prior-idle-ms = <250>;
        };

        bksp {
            bindings = <&kp BACKSPACE>;
            key-positions = <22 23>;
            timeout-ms = <200>;
            require-prior-idle-ms = <200>;
        };

        esc {
            bindings = <&kp ESC>;
            key-positions = <9 11>;
            timeout-ms = <200>;
            require-prior-idle-ms = <250>;
        };
    };

    //

    macros {

        // wez narrow view
        wez_n: wez_n {
            label = "&WEZ_N";
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            tap-ms = <5>;
            wait-ms = <5>;
            bindings = <&kp RS(RG(RA(RC(SPACE))))>
                , <&kp N9>;
        };

        // wez random color
        wez_rc: wez_rc {
            label = "&WEZ_RC";
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            tap-ms = <5>;
            wait-ms = <5>;
            bindings = <&kp RS(RG(RA(RC(SPACE))))>
                , <&kp R>;
        };

        // :=
        col_eq: col_eq {
            label = "&COL_EQ";
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            tap-ms = <5>;
            wait-ms = <5>;
