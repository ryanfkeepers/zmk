            bindings = <&kp B>
                , <&kp O>;
        };

        // ty
        t_y: t_y {
            label = "&T_Y";
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            tap-ms = <5>;
            wait-ms = <5>;
            bindings = <&kp T>
                , <&kp Y>;
        };

        // you
        y_o_u: y_o_u {
            label = "&Y_O_U";
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            tap-ms = <5>;
            wait-ms = <5>;
            bindings = <&kp Y>
                , <&kp O>
                , <&kp U>;
        };

        // at
        a_y: a_y {
            label = "&A_Y";
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            tap-ms = <5>;
