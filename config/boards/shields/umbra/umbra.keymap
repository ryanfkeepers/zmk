#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>

/*
 *                       UNIVERSAL KEY POSITION NAMES
 *      https://github.com/skarrmann/umbra/blob/main/firmware/kmk/kb.py
 *     ╭─────────────────────╮                  ╭─────────────────────╮
 *     │   0   1   2   3   4 │                  │ 21  22  26  27  28  │
 *     │   8   7   6   5     │                  │     20  10  18  17  │
 *     ╰────────╮  9  10  11 │                  │ 12  13  14 ╭────────╯
 *              ╰────────────╯                  ╰────────────╯
 */

#define DEF 0
#define ALPHA2 1
#define SYM 2
#define NAV 3
#define WIN 4

/ {
    behaviors {

        // hold for qu, tap for kp
        ht_qu: ht_qu {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <200>;
            bindings = <&q_u>, <&kp>;
            flavor = "tap-preferred";
        };

        ht: ht {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <200>;
            bindings = <&kp>, <&kp>;
            flavor = "tap-preferred";
            require-prior-idle-ms = <500>;
        };

        // hold tap, no prior idle
        ht_npi: ht_npi {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <200>;
            bindings = <&kp>, <&kp>;
            flavor = "tap-preferred";
        };

        // hold for ing, tap for kp
        ht_ing: ht_ing {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <200>;
            bindings = <&i_n_g>, <&kp>;
            flavor = "tap-preferred";
        };

        // hold for ck, tap for kp
        ht_ck: ht_ck {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <200>;
            bindings = <&c_k>, <&kp>;
            flavor = "tap-preferred";
