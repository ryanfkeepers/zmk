                , <&kp B>;
        };

        // fl
        f_l: f_l {
            label = "&F_L";
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            tap-ms = <5>;
            wait-ms = <5>;
            bindings = <&kp F>
                , <&kp L>;
        };

        // lt
        l_t: l_t {
